{
  "name": "@ids/finance-tracker",
  "version": "1.0.0",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run dev:frontend & npm run dev:backend & npm run dev:electron",
    "dev:frontend": "vite",
    "dev:backend": "tsc -w -p tsconfig.server.json",
    "dev:electron": "electron .",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "vite build",
    "build:backend": "tsc -p tsconfig.server.json",
    "package": "electron-builder build --win --linux"
  },
  "dependencies": {
    "@ids/finance-frontend": "*",
    "@ids/database-core": "*",
    "@ids/network-wizard": "*",
    "@ids/ui-components": "*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^0.435.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^8.0.8"
  },
  "build": {
    "appId": "com.idsworks.financetracker",
    "productName": "IDS Finance Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
